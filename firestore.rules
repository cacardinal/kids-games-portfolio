rules_version = '2';
service cloud.firestore {
  match /databases/{db}/documents {
    // One document per family account, keyed by the auth uid.
    // A family can read/write ONLY its own doc; nothing else is reachable.
    match /families/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
